#!/bin/sh
# GRUB 2.12 requires -p/--prefix, but live-build's lb_binary_iso omits it.
# Install a wrapper that auto-adds -p /boot/grub when missing.
cat > /usr/local/bin/grub-mkimage << 'WRAPPER'
#!/bin/sh
real_grub="/usr/bin/grub-mkimage"
has_prefix=false
for arg in "$@"; do
    case "$arg" in
        -p|--prefix|--prefix=*) has_prefix=true ;;
    esac
done
if [ "$has_prefix" = false ]; then
    set -- "$@" -p /boot/grub
fi
exec "$real_grub" "$@"
WRAPPER
chmod +x /usr/local/bin/grub-mkimage
